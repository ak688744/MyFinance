# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# raw financial statements / exports — contain PII (name, PAN, mobile). NEVER commit.
*.xlsx
*.xls
*.csv
/Mutual_Funds_*

# local SQLite databases (runtime/demo) — never commit
*.db
*.db-shm
*.db-wal

# manual-test screenshots (runtime artifacts)
apps/web/test-screenshots/*.png

# IDE / editor config (machine-specific)
.idea/
.cursor/

# local AI tooling runtime artifacts (machine-specific paths)
.ai-memory/
.playwright-mcp/
.mcp.json

# build artifacts
*.apk
